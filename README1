1. Main.java (Project Entry Point)

Add logger at top.

private static final Logger logger =
        LogManager.getLogger(Main.class);
Start of main()
logger.info("=================================================");
logger.info("Starting Axiomatics ALFA Automation");
logger.info("=================================================");
After reading input parameters
logger.info("Input Excel File: {}", excelPath);
logger.info("Output Directory: {}", outputDir);
Before reading roles
logger.info("Reading Roles Overview sheet");
After roles loaded
logger.info("Total roles loaded: {}", roles.size());
Before API processing
logger.info("Reading Service & Role Mapping sheet");
Before UI processing
logger.info("Reading UI & Feature Mapping sheet");
Before writing files
logger.info("Generating ALFA files...");
After each file
logger.info("api.alfa generated successfully");
logger.info("menu.alfa generated successfully");
logger.info("uiFeature.alfa generated successfully");
End of execution
logger.info("Automation completed successfully");
Catch block
logger.error("Automation failed", e);
2. RoleExcelReader

Logger:

private static final Logger logger =
        LogManager.getLogger(RoleExcelReader.class);
When sheet starts
logger.info("Processing Roles Overview sheet");
When role read

(DEBUG level)

logger.debug("Reading role: {}", rawRoleName);
When skipping strike-through
logger.warn("Skipping deprecated role: {}", rawRoleName);
When LDAP DN missing
logger.error("LDAP DN missing for role '{}' at row {}", rawRoleName, rowIndex + 1);
When role added
logger.debug("Added role {} with LDAP {}", roleName, ldapDn);
After completion
logger.info("Total valid roles loaded: {}", roles.size());
3. MenuExcelReader

Logger:

private static final Logger logger =
        LogManager.getLogger(MenuExcelReader.class);
Start
logger.info("Processing Domain & Role Mapping sheet");
When domain detected
logger.debug("Detected domain: {}", domain);
When role granted permission
logger.debug("Role {} permitted for domain {}", role, domain);
Invalid matrix value
logger.error("Invalid value '{}' at row {}, column {}", value, rowIndex + 1, colIndex + 1);
Domain with no roles
logger.warn("Domain '{}' has no permitted roles", domain);
End summary
logger.info("Total domains processed: {}", domainMappings.size());
4. ApiExcelReader

Logger:

private static final Logger logger =
        LogManager.getLogger(ApiExcelReader.class);
Start
logger.info("Processing Service & Role Mapping sheet");
Header detection
logger.debug("Detected service {} with operation {}", service, operation);
Duplicate detection
logger.error("Duplicate Service-Operation combination detected: {} - {}", service, operation);
Role row read
logger.debug("Processing role {}", roleName);
Permission grant
