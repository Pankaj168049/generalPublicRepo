5. UiExcelReader

Logger:

private static final Logger logger =
        LogManager.getLogger(UiExcelReader.class);
Start
logger.info("Processing UI & Feature Mapping sheet");
Column mapping
logger.debug("Mapped column {} -> {} > {} > {} > {}", col, ss, comp, feat, sec);
Role row
logger.debug("Processing role {}", role);
Permission parsing
logger.debug("Permission '{}' parsed for role {}", value, role);
Adding permission
logger.debug("Role {} allowed for action {} at {} > {} > {} > {}",
        role, action, path[0], path[1], path[2], path[3]);
Invalid CRUD
logger.error("Invalid CRUD permission '{}' at row {}", value, rowIndex + 1);
Unknown role
logger.error("Unknown role '{}' found in UI sheet", role);
End summary
logger.info("UI hierarchy built successfully");
